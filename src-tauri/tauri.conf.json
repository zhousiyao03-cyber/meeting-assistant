{
  "productName": "Meeting Assistant",
  "version": "0.1.0",
  "identifier": "com.meeting-assistant.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Meeting Copilot",
        "width": 420,
        "height": 840,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
